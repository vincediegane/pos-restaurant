<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_resto_super_admin" model="res.groups">
        <field name="name">Super admin restaurant</field>
        <field name="category_id" ref="base.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('point_of_sale.group_pos_manager')),
            (4, ref('stock.group_stock_manager')),
        ]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="base.user_admin" model="res.users">
            <field name="resto_role">super_admin</field>
        </record>
    </data>

    <record id="group_resto_manager" model="res.groups">
        <field name="name">Manager restaurant</field>
        <field name="category_id" ref="base.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('point_of_sale.group_pos_manager')),
            (4, ref('stock.group_stock_user')),
        ]"/>
    </record>

    <record id="group_resto_cashier" model="res.groups">
        <field name="name">Caissier restaurant</field>
        <field name="category_id" ref="base.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('point_of_sale.group_pos_user')),
        ]"/>
    </record>

    <record id="group_resto_stock_manager" model="res.groups">
        <field name="name">Responsable stock restaurant</field>
        <field name="category_id" ref="base.module_category_point_of_sale"/>
        <field name="implied_ids" eval="[
            (4, ref('base.group_user')),
            (4, ref('stock.group_stock_manager')),
        ]"/>
    </record>
</odoo>
