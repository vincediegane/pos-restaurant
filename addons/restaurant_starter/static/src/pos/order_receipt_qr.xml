<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('after-footer')]" position="before">
            <div t-if="props.data.resto_qr_code">
                <br/>
                <div class="pos-receipt-order-data mb-2">Merci de votre visite !</div>
                <img t-att-src="props.data.resto_qr_code" class="pos-receipt-qrcode"/>
            </div>
        </xpath>
    </t>
</templates>
