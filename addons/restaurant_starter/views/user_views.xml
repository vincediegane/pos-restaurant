<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resto_users_form" model="ir.ui.view">
        <field name="name">res.users.resto.form</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='access_rights']" position="inside">
                <separator string="Acces Restaurant"/>
                <group>
                    <field name="resto_role" required="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_resto_users_tree" model="ir.ui.view">
        <field name="name">res.users.resto.tree</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <field name="login" position="after">
                <field name="resto_role"/>
            </field>
        </field>
    </record>

    <record id="action_resto_res_users" model="ir.actions.act_window">
        <field name="name">Utilisateurs</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[("resto_role", "!=", False)]</field>
        <field name="context">{"default_resto_role": "cashier"}</field>
        <field name="help" type="html">
            <p>Gerer les utilisateurs du restaurant et leurs roles.</p>
        </field>
    </record>

    <!-- Sans ceci, Odoo choisit la vue formulaire "simplifiee" (base.view_users_simple_form,
         priority=1, invitation d'un nouvel utilisateur) plutot que notre formulaire complet
         herite de base.view_users_form : les roles restaurant restent invisibles pour tout
         utilisateur sans le groupe base.group_system (donc pour tous nos roles restaurant). -->
    <record id="action_resto_res_users_view_tree" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_resto_users_tree"/>
        <field name="act_window_id" ref="action_resto_res_users"/>
    </record>
    <record id="action_resto_res_users_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_resto_users_form"/>
        <field name="act_window_id" ref="action_resto_res_users"/>
    </record>
</odoo>
